{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "System Schema",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "build": { "type": "string" },
    "environment": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "required": ["version", "environment"]
}
