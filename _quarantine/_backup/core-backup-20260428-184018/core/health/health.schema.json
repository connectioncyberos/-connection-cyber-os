{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Health Schema",
  "type": "object",
  "properties": {
    "status": { "type": "string", "enum": ["UP", "DOWN"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "details": { "type": "object" }
  },
  "required": ["status", "timestamp"]
}
