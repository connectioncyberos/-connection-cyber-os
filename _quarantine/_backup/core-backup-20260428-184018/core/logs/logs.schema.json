{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Logs Schema",
  "type": "object",
  "properties": {
    "level": { "type": "string", "enum": ["info", "warn", "error", "critical"] },
    "message": { "type": "string" },
    "context": { "type": "object" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "required": ["level", "message"]
}
