{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Global Config Schema",
  "type": "object",
  "properties": {
    "key": { "type": "string" },
    "value": {},
    "environment": { "type": "string", "enum": ["dev", "stage", "prod"] },
    "module": { "type": "string" },
    "portal": { "type": "string" }
  },
  "required": ["key", "value"]
}
